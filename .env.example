# --- Free local: Ollama (https://ollama.com) ---
# 1) Install Ollama, then:  ollama pull llama3
# 2) Server runs at localhost:11434 (often starts with the app)
# 3) Copy this file to .env and adjust model names if you use another pull (e.g. mistral, llama3.2)
OPENAI_API_KEY=ollama
OPENAI_BASE_URL=http://localhost:11434/v1
INTERVIEW_MODEL=llama3
EVALUATOR_MODEL=llama3

# --- Optional: cloud (OpenRouter) — replace the block above ---
# OPENAI_API_KEY=your_key_here
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# INTERVIEW_MODEL=meta-llama/llama-3.1-8b-instruct:free
# EVALUATOR_MODEL=meta-llama/llama-3.1-8b-instruct:free
